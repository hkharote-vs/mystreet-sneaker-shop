# Active profile: dev | prod
SPRING_PROFILES_ACTIVE=dev

# JWT (RS256 key pair — generated via GenKeys.java, see README)
# For dev these point to classpath resources — no change needed
JWT_PRIVATE_KEY=classpath:certs/private.pem
JWT_PUBLIC_KEY=classpath:certs/public.pem
JWT_EXPIRY_HOURS=24

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Production only — leave blank for dev (H2 is used)
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=
